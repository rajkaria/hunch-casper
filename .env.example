# Hunch on Casper — environment. All optional: sensible public defaults live in
# src/config/network.ts. Set these on the Vercel project as contracts land (S1+).

# Default network the UI opens on ("testnet" | "mainnet")
NEXT_PUBLIC_DEFAULT_NETWORK=testnet

# --- Testnet ---
NEXT_PUBLIC_CASPER_TESTNET_RPC=https://rpc.testnet.casperlabs.io/rpc
NEXT_PUBLIC_CSPR_CLOUD_TESTNET=https://api.testnet.cspr.cloud
NEXT_PUBLIC_CASPER_TESTNET_EXPLORER=https://testnet.cspr.live
NEXT_PUBLIC_TESTNET_MARKET_FACTORY=
NEXT_PUBLIC_TESTNET_ORACLE_REGISTRY=
NEXT_PUBLIC_TESTNET_VAULT=

# --- Mainnet ---
NEXT_PUBLIC_CASPER_MAINNET_RPC=https://rpc.mainnet.casperlabs.io/rpc
NEXT_PUBLIC_CSPR_CLOUD_MAINNET=https://api.cspr.cloud
NEXT_PUBLIC_CASPER_MAINNET_EXPLORER=https://cspr.live
NEXT_PUBLIC_MAINNET_MARKET_FACTORY=
NEXT_PUBLIC_MAINNET_ORACLE_REGISTRY=
NEXT_PUBLIC_MAINNET_VAULT=

# CSPR.cloud API key (server-side; used by feed adapters from S3+)
CSPR_CLOUD_API_KEY=

# LLM provider (agent narration only — never the money path). AI Gateway model string.
LLM_MODEL=anthropic/claude-sonnet-5
LLM_API_KEY=
