# Hunch on Casper — environment. All optional: sensible public defaults live in
# src/config/network.ts. Set these on the Vercel project as contracts land (S1+).

# Default network the UI opens on ("testnet" | "mainnet")
NEXT_PUBLIC_DEFAULT_NETWORK=testnet

# --- Testnet ---
NEXT_PUBLIC_CASPER_TESTNET_RPC=https://node.testnet.casper.network/rpc
NEXT_PUBLIC_CSPR_CLOUD_TESTNET=https://api.testnet.cspr.cloud
NEXT_PUBLIC_CASPER_TESTNET_EXPLORER=https://testnet.cspr.live
NEXT_PUBLIC_TESTNET_MARKET_FACTORY=
NEXT_PUBLIC_TESTNET_ORACLE_REGISTRY=
NEXT_PUBLIC_TESTNET_VAULT=
# S16 singleton HunchVault v2 (contracts/src/hunch_vault.rs). When set, slugs NOT in
# NEXT_PUBLIC_TESTNET_MARKET_ADDRS route here with the slug as the market_id runtime arg
# (cheap create_market entries — no per-market installs). Legacy per-market packages in
# the map keep winning, so the five pre-S16 deploys stay routable unchanged.
NEXT_PUBLIC_TESTNET_VAULT_V2=
# Per-market ParimutuelMarket package hashes from the full-catalogue deploy (slug → hash-<64hex>,
# JSON). Bets/resolves route to the market's own contract; unmapped slugs fall back to _VAULT.
# e.g. {"the-flip":"hash-…","cspr-above-5c-aug1":"hash-…"}
NEXT_PUBLIC_TESTNET_MARKET_ADDRS=

# --- Mainnet ---
NEXT_PUBLIC_CASPER_MAINNET_RPC=https://node.mainnet.casper.network/rpc
NEXT_PUBLIC_CSPR_CLOUD_MAINNET=https://api.cspr.cloud
NEXT_PUBLIC_CASPER_MAINNET_EXPLORER=https://cspr.live
NEXT_PUBLIC_MAINNET_MARKET_FACTORY=
NEXT_PUBLIC_MAINNET_ORACLE_REGISTRY=
NEXT_PUBLIC_MAINNET_VAULT=
NEXT_PUBLIC_MAINNET_VAULT_V2=
NEXT_PUBLIC_MAINNET_MARKET_ADDRS=

# CSPR.cloud API key (server-side). With a key, Genesis reads a LIVE validator count from
# CSPR.cloud; without one it falls back to the network's public node RPC (latest block height),
# then to the deterministic demo rotation. Set CASPER_LIVE_SIGNALS=false to force the rotation.
CSPR_CLOUD_API_KEY=
CASPER_LIVE_SIGNALS=

# On-chain proof receipts — real tx hashes minted by the ops deploy, rendered as cspr.live links
# on the landing page ("Live on Casper") + docs. JSON array of {label, hash, network}, e.g.
# [{"label":"First real bet (payable proxy)","hash":"<64 hex>","network":"testnet"}]
NEXT_PUBLIC_ONCHAIN_RECEIPTS=

# --- Real Casper chain adapter (S2) ---
# Default is the mock adapter (deterministic, credential-free) so CI + the demo need no secrets.
# Set to "real" to sign + submit live Casper transactions via casper-js-sdk (server-only).
CASPER_CHAIN_MODE=mock
# Ed25519 secret key that signs + funds bets — PEM contents (casper-client keygen secret_key.pem)
# or a 32-byte hex seed. Server-only; NEVER prefix NEXT_PUBLIC_.
CASPER_BETTOR_KEY=
# Ed25519 secret key for the oracle's resolve. Falls back to CASPER_BETTOR_KEY when unset.
CASPER_ORACLE_KEY=
# Odra's proxy_caller_with_return.wasm (needed to attach CSPR to a payable bet) ships in-repo
# at src/adapters/casper/resources/. Set this ONLY to override that bundled copy.
CASPER_PROXY_WASM_PATH=
# Operator resolve route (/api/chain/resolve). MOCK mode: on unless set to "false".
# REAL mode: FAIL-CLOSED — the route stays disabled unless this is exactly "true" AND a
# matching CASPER_RESOLVE_OPERATOR_TOKEN is presented (resolution is a money-path authority;
# the autonomous Arbiter replaces this operator gate in S6+).
CASPER_ENABLE_RESOLVE_ROUTE=true
# Shared secret required (real mode only) in the `x-operator-token` header to POST a resolve.
CASPER_RESOLVE_OPERATOR_TOKEN=
# Real-mode agent x402 rail. In real chain mode the rail (`/api/agent/v1/bet`, MCP place_bet,
# the Prophet fleet) is OFF unless ONE of the two below is set. Mock mode (default) is unaffected.
#
# Operator treasury account (Casper public key hex or account-hash-…) agent x402 payments must
# land in. Setting it wires the REAL transfer-verifying PaymentPort in real mode: a payment proof
# is accepted only if its deployHash is a SUCCESSFUL on-chain native CSPR transfer from the payer
# to this account of at least the quoted amount (trustless verification, node-RPC read, no key).
# Note: the internal Prophet fleet fabricates mock proofs, so with this set the fleet cannot bet
# in real mode unless it funds genuine transfers — external agents paying real CSPR are the point.
CASPER_X402_PAYTO=
# Weaker legacy opt-in: keep the MOCK PaymentPort in real mode (proofs verified by nonce-match
# only, NOT an on-chain-transfer check). Set to exactly "true" to accept that trade-off; prefer
# CASPER_X402_PAYTO above.
CASPER_REAL_AGENT_X402=
# Show the operator "Oracle resolve" control on market detail pages. OFF by default (the autonomous
# Arbiter resolves); set to "true" only to demo the S2 thin-slice resolve path.
NEXT_PUBLIC_SHOW_DEMO_RESOLVE=

# --- Economy heartbeat ---
# Shared secret for the scheduled tick (/api/agent/tick). The credential-free mock demo accepts
# unauthenticated ticks; in REAL mode the tick moves the money path, so it is gated. Set the SAME
# value here and as the GitHub repo secret CRON_SECRET used by .github/workflows/economy.yml —
# real mode without it means every scheduled tick 401s and the economy stops advancing.
# TICK_CRON_SECRET is accepted as an alias. `GET /api/health` reports whether one is configured.
CRON_SECRET=
# Ceiling on Genesis-created markets from the open demo trigger (abuse guard). Default 12.
GENESIS_MAX_CREATED=

# LLM provider (agent narration only — never the money path). AI Gateway model string.
LLM_MODEL=anthropic/claude-sonnet-5
LLM_API_KEY=

# --- Economy-state persistence (Upstash Redis REST / Vercel KV) ---
# Unset (the default — local dev, CI, tests): the agent economy lives in per-instance memory and
# the deterministic demo seed papers over cold starts, so a judge's bet can vanish when the next
# request lands on a different serverless instance. Set EITHER pair below and every economy
# mutation (bets, settlements, Genesis-created markets, the activity feed, oracle reputation) is
# snapshotted to a single KV key (hunch:economy:v1) and hydrated once per instance on cold start —
# judges' bets and the boards persist across instances and deploys, and a hydrated instance never
# re-seeds demo history on top. Writes are debounced/coalesced and last-write-wins across
# instances (fine: the cron tick is effectively the single writer; the chain stays the source of
# truth for money). KV downtime is harmless — 3s timeout, then the app continues in-memory.
# Vercel KV / Upstash-via-Vercel-marketplace variable names (these win when both pairs are set):
KV_REST_API_URL=
KV_REST_API_TOKEN=
# ...or the plain Upstash Redis REST names:
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
