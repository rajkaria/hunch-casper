# Odra livenet deploy config for `cargo run --bin contracts_cli -- deploy`.
# Copy to contracts/.env and fill in. NEVER commit the real .env or secret key.

# JSON-RPC node endpoint.
#   testnet: https://rpc.testnet.casperlabs.io/rpc
#   mainnet: https://rpc.mainnet.casperlabs.io/rpc
ODRA_CASPER_LIVENET_NODE_ADDRESS=https://rpc.testnet.casperlabs.io/rpc

# Chain name used when signing deploys.
#   testnet: casper-test
#   mainnet: casper
ODRA_CASPER_LIVENET_CHAIN_NAME=casper-test

# Path to your funded secret key (PEM). Generate with `casper-client keygen ./keys`,
# then fund the public key at https://testnet.cspr.live/tools/faucet
ODRA_CASPER_LIVENET_SECRET_KEY_PATH=./keys/secret_key.pem
